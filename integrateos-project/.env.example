# Pooled Postgres connection (Neon recommended — installed via the Vercel
# marketplace integration which populates both URLs automatically).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/integrateos?sslmode=require"

# Direct connection used by `prisma migrate deploy`.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/integrateos?sslmode=require"
