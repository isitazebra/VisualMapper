// IntegrateOS — B2B mapping platform
// See CLAUDE.md for domain context

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev, "rhel-openssl-3.0.x" for Vercel's Node 20 runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for serverless runtime queries.
  url       = env("DATABASE_URL")
  // Direct connection used by `prisma migrate` (Neon integration sets
  // both when you install it from Vercel).
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Custom schema (source or target) inferred from an uploaded sample ───
// Built-in schemas live in code (src/lib/schemas/registry.ts); custom
// ones live here. MappingSpec.sourceSchemaId / targetSchemaId can point
// at either — the id convention is `custom:<cuid>` for rows in this
// table.
model Schema {
  id          String   @id
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  role        String   // "source" | "target" | "both"
  format      String   // "x12" | "xml" | "json" | "otm_xml" | "csv"
  displayName String
  description String?
  nodes       Json     // SchemaNode[] — see src/lib/types.ts
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([partnerId])
  @@index([format, role])
}

// ─── Partners (trading partners being onboarded) ───
model Partner {
  id          String   @id @default(cuid())
  name        String
  scac        String?  // Standard Carrier Alpha Code
  type        String   // "carrier" | "shipper" | "3pl" | "customer"
  status      String   @default("onboarding") // onboarding | active | paused
  contactName String?
  contactEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mappings  MappingSpec[]
  schemas   Schema[]
  lookups   LookupTable[]
  endpoints Endpoint[]
  runs      TransactionRun[]
}

// ─── Runtime ────────────────────────────────────────────────────────
// An ingress Endpoint binds an opaque token to a mapping spec. Inbound
// requests at /api/ingress/:token get transformed via the mapping and
// either returned synchronously (mode=sync) or forwarded to egressUrl
// (mode=forward). Each inbound request produces exactly one
// TransactionRun row capturing the full lifecycle.
model Endpoint {
  id            String      @id @default(cuid())
  partnerId     String
  partner       Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  mappingSpecId String
  mappingSpec   MappingSpec @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  name          String
  // Opaque token baked into the ingress URL. Rotate to rotate the URL.
  token         String      @unique
  // "sync" → return the transformed output in the response body
  // "forward" → HTTP POST to egressUrl and return 202 to caller
  mode          String      @default("sync")
  egressUrl     String?
  // Extra HTTP headers sent on egress (JSONB map k→v).
  egressHeaders Json?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  runs TransactionRun[]

  @@index([partnerId])
  @@index([mappingSpecId])
}

// One row per inbound request. Captures input, output, status, timing,
// and egress result (when mode=forward).
model TransactionRun {
  id               String    @id @default(cuid())
  endpointId       String
  endpoint         Endpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  partnerId        String
  partner          Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  mappingSpecId    String
  mappingSpec      MappingSpec @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  // "received" → just arrived
  // "transformed" → successful transform, egress not applicable or pending
  // "delivered" → forwarded successfully (mode=forward)
  // "failed" → something broke (see errorStage + errorMessage)
  status           String
  inputPayload     String    @db.Text
  outputPayload    String?   @db.Text
  inputSize        Int
  outputSize       Int?
  mappedCount      Int?
  unmappedCount    Int?
  transactionCount Int?
  errorMessage     String?
  errorStage       String?   // "parse" | "transform" | "emit" | "egress"
  egressStatus     Int?
  egressBody       String?   @db.Text
  egressError      String?
  receivedAt       DateTime  @default(now())
  transformedAt    DateTime?
  deliveredAt      DateTime?
  durationMs       Int?

  @@index([endpointId, receivedAt(sort: Desc)])
  @@index([partnerId, receivedAt(sort: Desc)])
  @@index([mappingSpecId])
  @@index([status])
}

// ─── Lookup table for the `lookup` rule type ───
// Partner-scoped when partnerId is set, global when null. Entries is a
// JSONB object mapping string keys to string values (e.g. UOM code
// translations, status-code taxonomies, country-code conversions when
// the built-in formulas aren't enough).
model LookupTable {
  id          String   @id @default(cuid())
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  entries     Json
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([partnerId])
  @@index([name])
}

// ─── A mapping spec (one transaction type × direction for a partner) ───
model MappingSpec {
  id           String  @id @default(cuid())
  partnerId    String
  partner      Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name         String
  // Legacy shape — still written on create for built-in X12 mappings.
  // Phase 2.2 will make these nullable once custom schemas land.
  txType       String  // "204" | "214" | "210" | "990" | "850" | "855" | "856" | "810"
  ediVersion   String  // "3040" | "4010" | "4030" | "5010"
  sourceFormat String  // "x12" | "json" | "xml" | "csv" | ...
  targetFormat String  // "xml" | "json" | "otm_xml" | "csv" | ...
  // Schema registry references. Built-in ids look like "x12:204" / "xml:850"
  // / "json:default"; custom ids look like "custom:<cuid>" once Phase 2.2
  // ships. Nullable while the codebase transitions — existing rows are
  // backfilled by 1_add_schema_ids migration.
  sourceSchemaId String?
  targetSchemaId String?
  direction    String  @default("inbound") // inbound | outbound
  status       String  @default("draft") // draft | review | confirmed | live
  // Optional saved sample payload used by the studio's live preview.
  // Persisted so it survives page refreshes. Shape is free-form — the
  // format is determined by the source schema.
  samplePayload String? @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fieldMappings FieldMapping[]
  loopConfigs   LoopConfig[]
  comments      Comment[]
  changeLog     ChangeLogEntry[]
  endpoints     Endpoint[]
  runs          TransactionRun[]

  @@index([partnerId])
  @@index([txType, ediVersion])
  @@index([sourceSchemaId])
  @@index([targetSchemaId])
}

// ─── Individual source-to-target field mapping (the base rule) ───
model FieldMapping {
  id            String      @id @default(cuid())
  mappingSpecId String
  mappingSpec   MappingSpec @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  sourceFieldId String      // schema node id, e.g. "b204" (B2*04)
  targetFieldId String      // target schema node id, e.g. "tx06" (shipmentIdentificationNumber)
  ruleType      String      // direct | hardcode | conditional | suppress | currentDate | currentTime
                            // | autoIncrement | concat | lookup | formula | parseXml
                            // | dateFormat | passthrough | hlCounter | splitField
  value         String?     // The hardcoded/formula/lookup value (type depends on ruleType)
  condition     String?     // Optional predicate for conditional rules
  notes         String?     // Free-form notes from the mapper
  confirmed     Boolean     @default(false)
  createdBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  overrides CustomerOverride[]
  comments  Comment[]

  @@index([mappingSpecId])
  @@index([sourceFieldId])
  @@index([targetFieldId])
}

// ─── Customer-specific override stacked on top of a base FieldMapping ───
model CustomerOverride {
  id             String       @id @default(cuid())
  fieldMappingId String
  fieldMapping   FieldMapping @relation(fields: [fieldMappingId], references: [id], onDelete: Cascade)
  customerName   String       // "UPS SCS", "Kroger", "Elanco", etc.
  ruleType       String
  value          String?
  condition      String?      // "If ISA*06 = ELOGEX" etc.
  active         Boolean      @default(true)
  priority       Int          @default(0) // ordering when multiple overrides match
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([fieldMappingId])
  @@index([customerName])
}

// ─── How a repeating loop (N1 parties, S5 stops, etc.) is handled ───
model LoopConfig {
  id            String      @id @default(cuid())
  mappingSpecId String
  mappingSpec   MappingSpec @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  loopId        String      // schema node id for the loop, e.g. "s5" or "n1h"
  operation     String      // copy_all | filter | first | aggregate
  condition     String?     // e.g. "entityCode = SH"
  limit         Int?        // optional max iterations
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([mappingSpecId])
}

// ─── Threaded collaboration comment (on spec or on a specific field mapping) ───
model Comment {
  id             String        @id @default(cuid())
  mappingSpecId  String
  mappingSpec    MappingSpec   @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  fieldMappingId String?
  fieldMapping   FieldMapping? @relation(fields: [fieldMappingId], references: [id], onDelete: Cascade)
  author         String
  text           String
  resolved       Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([mappingSpecId])
  @@index([fieldMappingId])
}

// ─── Audit trail for change log ───
model ChangeLogEntry {
  id            String      @id @default(cuid())
  mappingSpecId String
  mappingSpec   MappingSpec @relation(fields: [mappingSpecId], references: [id], onDelete: Cascade)
  author        String
  action        String      // "created" | "updated" | "confirmed" | "override_added" | ...
  summary       String
  payload       Json?       // optional before/after snapshot
  createdAt     DateTime    @default(now())

  @@index([mappingSpecId])
}
